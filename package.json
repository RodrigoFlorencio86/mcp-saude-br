{
  "name": "mcp-saude-br",
  "version": "1.2.0",
  "description": "MCP Server para dados de medicamentos brasileiros (ANVISA, CMED, Bulário Eletrônico)",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "mcp-saude-br": "dist/index.js"
  },
  "files": [
    "dist/",
    "assets/",
    "README.md"
  ],
  "keywords": [
    "mcp",
    "anvisa",
    "medicamentos",
    "saude",
    "brasil",
    "claude"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RodrigoFlorencio86/mcp-saude-br.git"
  },
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest",
    "test:run": "vitest run",
    "download-data": "tsx src/data/loader.ts",
    "build-release": "tsx scripts/build-data-release.ts",
    "inspect": "npx @modelcontextprotocol/inspector node dist/index.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "adm-zip": "^0.5.16",
    "axios": "^1.13.6",
    "cheerio": "^1.2.0",
    "csv-parse": "^6.1.0",
    "node-cache": "^5.1.2",
    "p-queue": "^9.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.0",
    "@types/node": "^25.4.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
